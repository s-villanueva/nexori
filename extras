--FUNCION PARA LLAMAR AL PROCEDURE PORQUE SUPA SOLO DETECTA FUNCIONES 
CREATE OR REPLACE FUNCTION f_empresa_nueva(
    p_empresa_datos JSONB,
    p_empresa_contactos JSONB,
    p_empresa_sucursales JSONB
)
RETURNS void
LANGUAGE plpgsql
AS $$
BEGIN
    CALL p_empresa_nueva(
        p_empresa_datos,
        p_empresa_contactos,
        p_empresa_sucursales
    );
END;
$$;

--FUNCION AUXILIAR PARA CREAR ORDEN 
CREATE OR REPLACE FUNCTION f_agregar_orden_compra(
    p_nombre_empresa_compradora VARCHAR,
    p_nombre_empresa_proveedora VARCHAR,
    p_nombre_sucursal VARCHAR,
    p_nombre_almacen VARCHAR,
    p_nombre_usuario VARCHAR,
    p_productos_lista JSONB
)
RETURNS void
LANGUAGE plpgsql
AS $$
BEGIN
    CALL SP_AGREGAR_ORDEN_COMPRA(
        p_nombre_empresa_compradora,
        p_nombre_empresa_proveedora,
        p_nombre_sucursal,
        p_nombre_almacen,
        p_nombre_usuario,
        p_productos_lista
    );
END;
$$;
