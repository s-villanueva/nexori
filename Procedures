- añadir una regla de tarifa y sus tramos -> verificar que no exista una regla de tarifa con ese nombre del mismo proveedor

CREATE OR REPLACE PROCEDURE SP_AGREGAR_REGLA_TARIFA_CON_TRAMOS(
    P_NOMBRE VARCHAR,
    P_DESCRIPCION TEXT,
    P_ID_PROVEEDOR UUID,
    P_TRAMOS JSONB
)
    
AS $$
DECLARE
    V_ID_PROVEEDOR UUID;
    V_ID_REGLA_EXISTENTE UUID;
    V_ID_REGLA_NUEVA UUID;
BEGIN
    -- validar que el proveedor exista
    SELECT p.id_proveedor
    INTO V_ID_PROVEEDOR
    FROM proveedor p
    WHERE p.id_proveedor = P_ID_PROVEEDOR;

    IF V_ID_PROVEEDOR IS NULL THEN
        RAISE EXCEPTION 'El proveedor con ID % no existe', P_ID_PROVEEDOR;
    END IF;

    -- verificar que no exista regla con el mismo nombre para el proveedor
    SELECT tr.id_tarifa
    INTO V_ID_REGLA_EXISTENTE
    FROM tarifa_regla tr
    WHERE LOWER(tr.nombre) = LOWER(P_NOMBRE)
      AND tr.id_proveedor = P_ID_PROVEEDOR
    LIMIT 1;

    IF V_ID_REGLA_EXISTENTE IS NOT NULL THEN
        RAISE EXCEPTION 'Ya existe una regla de tarifa con el nombre % para este proveedor', P_NOMBRE;
    END IF;

    -- ver si en json hay minimo 1 tramo
    IF P_TRAMOS IS NULL OR jsonb_array_length(P_TRAMOS) = 0 THEN
        RAISE EXCEPTION 'Debe enviar al menos un tramo para la regla de tarifa';
    END IF;

    -- validar que todos los tramos tengan tipo
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'tipo' IS NULL
           OR tramo->>'tipo' = ''
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener tipo';
    END IF;

    -- validar que el tipo sea volumen o costo
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'tipo' NOT IN ('volumen', 'costo')
    ) THEN
        RAISE EXCEPTION 'Uno o mas tramos tienen tipo invalido. Solo se permite volumen o costo';
    END IF;

    -- validar que cantidad_minima exista y no sea negativa o nula
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'cantidad_minima' IS NULL
           OR tramo->>'cantidad_minima' = ''
           OR (tramo->>'cantidad_minima')::DECIMAL(14,2) < 0
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener cantidad_minima y no puede ser negativa';
    END IF;

    -- Validar que cantidad_maxima sea mayor a cantidad_minima cuando exista
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'cantidad_maxima' IS NOT NULL
          AND tramo->>'cantidad_maxima' <> ''
          AND (tramo->>'cantidad_maxima')::DECIMAL(14,2)
            <= (tramo->>'cantidad_minima')::DECIMAL(14,2)
    ) THEN
        RAISE EXCEPTION 'La cantidad maxima debe ser mayor a la cantidad minima';
    END IF;

    -- Validar que porcentaje_desc exista
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'porcentaje_desc' IS NULL
           OR tramo->>'porcentaje_desc' = ''
            OR (tramo->>'porcentaje_desc')::DECIMAL(14,2) < 0
            OR (tramo->>'porcentaje_desc')::DECIMAL(14,2) > 100
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener porcentaje_desc';
    END IF;

    -- Validar que no existan tramos sobrepuestos del mismo tipo
    IF EXISTS (
        WITH tramos AS (
            SELECT
                ord,
                tramo->>'tipo' AS tipo,
                (tramo->>'cantidad_minima')::DECIMAL(14,2) AS cantidad_minima,
                NULLIF(tramo->>'cantidad_maxima', '')::DECIMAL(14,2) AS cantidad_maxima
            FROM jsonb_array_elements(P_TRAMOS) WITH ORDINALITY AS t(tramo, ord)
        )
        SELECT 1
        FROM tramos t1
                 JOIN tramos t2
                      ON t1.ord < t2.ord
                          AND t1.tipo = t2.tipo
        WHERE t1.cantidad_minima <= COALESCE(t2.cantidad_maxima, 999999999999)
          AND COALESCE(t1.cantidad_maxima, 999999999999) >= t2.cantidad_minima
    ) THEN
        RAISE EXCEPTION 'Existen tramos sobrepuestos para el mismo tipo de tarifa';
    END IF;

    -- crear la regla de tarifa
    INSERT INTO tarifa_regla (
        nombre,
        descripcion,
        id_proveedor,
        activo
    )
    VALUES (
               P_NOMBRE,
               P_DESCRIPCION,
               P_ID_PROVEEDOR,
               TRUE
           )
    RETURNING id_tarifa INTO V_ID_REGLA_NUEVA;

    -- nsertar los tramos
    INSERT INTO tramo_tarifa (
        tipo,
        cantidad_minima,
        cantidad_maxima,
        porcentaje_desc,
        id_regla
    )
    SELECT
        tramo->>'tipo',
        (tramo->>'cantidad_minima')::DECIMAL(14,2),
        NULLIF(tramo->>'cantidad_maxima', '')::DECIMAL(14,2),
        (tramo->>'porcentaje_desc')::DECIMAL(14,2),
        V_ID_REGLA_NUEVA
    FROM jsonb_array_elements(P_TRAMOS) AS tramo;

    RAISE INFO 'Regla de tarifa creada correctamente. ID regla: %', V_ID_REGLA_NUEVA;
END;
$$ LANGUAGE plpgsql;

