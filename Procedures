--------------------------------
-- añadir una regla de tarifa y sus tramos -> verificar que no exista una regla de tarifa con ese nombre del mismo proveedor
---------------------------
CREATE OR REPLACE PROCEDURE SP_AGREGAR_REGLA_TARIFA_CON_TRAMOS(
    P_NOMBRE VARCHAR,
    P_DESCRIPCION TEXT,
    P_ID_PROVEEDOR UUID,
    P_TRAMOS JSONB
)
    
AS $$
DECLARE
    V_ID_PROVEEDOR UUID;
    V_ID_REGLA_EXISTENTE UUID;
    V_ID_REGLA_NUEVA UUID;
BEGIN
    -- validar que el proveedor exista
    SELECT p.id_proveedor
    INTO V_ID_PROVEEDOR
    FROM proveedor p
    WHERE p.id_proveedor = P_ID_PROVEEDOR;

    IF V_ID_PROVEEDOR IS NULL THEN
        RAISE EXCEPTION 'El proveedor con ID % no existe', P_ID_PROVEEDOR;
    END IF;

    -- verificar que no exista regla con el mismo nombre para el proveedor
    SELECT tr.id_tarifa
    INTO V_ID_REGLA_EXISTENTE
    FROM tarifa_regla tr
    WHERE LOWER(tr.nombre) = LOWER(P_NOMBRE)
      AND tr.id_proveedor = P_ID_PROVEEDOR
    LIMIT 1;

    IF V_ID_REGLA_EXISTENTE IS NOT NULL THEN
        RAISE EXCEPTION 'Ya existe una regla de tarifa con el nombre % para este proveedor', P_NOMBRE;
    END IF;

    -- ver si en json hay minimo 1 tramo
    IF P_TRAMOS IS NULL OR jsonb_array_length(P_TRAMOS) = 0 THEN
        RAISE EXCEPTION 'Debe enviar al menos un tramo para la regla de tarifa';
    END IF;

    -- validar que todos los tramos tengan tipo
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'tipo' IS NULL
           OR tramo->>'tipo' = ''
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener tipo';
    END IF;

    -- validar que el tipo sea volumen o costo
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'tipo' NOT IN ('volumen', 'costo')
    ) THEN
        RAISE EXCEPTION 'Uno o mas tramos tienen tipo invalido. Solo se permite volumen o costo';
    END IF;

    -- validar que cantidad_minima exista y no sea negativa o nula
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'cantidad_minima' IS NULL
           OR tramo->>'cantidad_minima' = ''
           OR (tramo->>'cantidad_minima')::DECIMAL(14,2) < 0
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener cantidad_minima y no puede ser negativa';
    END IF;

    -- Validar que cantidad_maxima sea mayor a cantidad_minima cuando exista
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'cantidad_maxima' IS NOT NULL
          AND tramo->>'cantidad_maxima' <> ''
          AND (tramo->>'cantidad_maxima')::DECIMAL(14,2)
            <= (tramo->>'cantidad_minima')::DECIMAL(14,2)
    ) THEN
        RAISE EXCEPTION 'La cantidad maxima debe ser mayor a la cantidad minima';
    END IF;

    -- Validar que porcentaje_desc exista
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_TRAMOS) AS tramo
        WHERE tramo->>'porcentaje_desc' IS NULL
           OR tramo->>'porcentaje_desc' = ''
            OR (tramo->>'porcentaje_desc')::DECIMAL(14,2) < 0
            OR (tramo->>'porcentaje_desc')::DECIMAL(14,2) > 100
    ) THEN
        RAISE EXCEPTION 'Todos los tramos deben tener porcentaje_desc';
    END IF;

    -- Validar que no existan tramos sobrepuestos del mismo tipo
    IF EXISTS (
        WITH tramos AS (
            SELECT
                ord,
                tramo->>'tipo' AS tipo,
                (tramo->>'cantidad_minima')::DECIMAL(14,2) AS cantidad_minima,
                NULLIF(tramo->>'cantidad_maxima', '')::DECIMAL(14,2) AS cantidad_maxima
            FROM jsonb_array_elements(P_TRAMOS) WITH ORDINALITY AS t(tramo, ord)
        )
        SELECT 1
        FROM tramos t1
                 JOIN tramos t2
                      ON t1.ord < t2.ord
                          AND t1.tipo = t2.tipo
        WHERE t1.cantidad_minima <= COALESCE(t2.cantidad_maxima, 999999999999)
          AND COALESCE(t1.cantidad_maxima, 999999999999) >= t2.cantidad_minima
    ) THEN
        RAISE EXCEPTION 'Existen tramos sobrepuestos para el mismo tipo de tarifa';
    END IF;

    -- crear la regla de tarifa
    INSERT INTO tarifa_regla (
        nombre,
        descripcion,
        id_proveedor,
        activo
    )
    VALUES (
               P_NOMBRE,
               P_DESCRIPCION,
               P_ID_PROVEEDOR,
               TRUE
           )
    RETURNING id_tarifa INTO V_ID_REGLA_NUEVA;

    -- nsertar los tramos
    INSERT INTO tramo_tarifa (
        tipo,
        cantidad_minima,
        cantidad_maxima,
        porcentaje_desc,
        id_regla
    )
    SELECT
        tramo->>'tipo',
        (tramo->>'cantidad_minima')::DECIMAL(14,2),
        NULLIF(tramo->>'cantidad_maxima', '')::DECIMAL(14,2),
        (tramo->>'porcentaje_desc')::DECIMAL(14,2),
        V_ID_REGLA_NUEVA
    FROM jsonb_array_elements(P_TRAMOS) AS tramo;

    RAISE INFO 'Regla de tarifa creada correctamente. ID regla: %', V_ID_REGLA_NUEVA;
END;
$$ LANGUAGE plpgsql;

-----------------------
--- añadir un contrato con una empresa y el detalle del contrato -> verificar contratos activos con la empresa
--------------------
CREATE OR REPLACE PROCEDURE SP_AGREGAR_CONTRATO_EMPRESA_DETALLE(
    P_ID_EMPRESA UUID,
    P_ID_PROVEEDOR UUID,
    P_ID_REGLA UUID,
    P_VIGENTE_DESDE TIMESTAMP,
    P_VIGENTE_HASTA TIMESTAMP,
    P_DETALLES JSONB
)

AS $$
DECLARE
    V_ID_EMPRESA UUID;
    V_ID_PROVEEDOR UUID;
    V_ID_REGLA UUID;
    V_ID_CONTRATO_ACTIVO UUID;
    V_ID_CONTRATO_NUEVO UUID;
BEGIN
    -- validar empresa
    SELECT e.id_empresa
    INTO V_ID_EMPRESA
    FROM empresa e
    WHERE e.id_empresa = P_ID_EMPRESA;

    IF V_ID_EMPRESA IS NULL THEN
        RAISE EXCEPTION 'La empresa con ID % no existe', P_ID_EMPRESA;
    END IF;

    -- validar proveedor
    SELECT p.id_proveedor
    INTO V_ID_PROVEEDOR
    FROM proveedor p
    WHERE p.id_proveedor = P_ID_PROVEEDOR;

    IF V_ID_PROVEEDOR IS NULL THEN
        RAISE EXCEPTION 'El proveedor con ID % no existe', P_ID_PROVEEDOR;
    END IF;

    -- validar regla de tarifa
    SELECT tr.id_tarifa
    INTO V_ID_REGLA
    FROM tarifa_regla tr
    WHERE tr.id_tarifa = P_ID_REGLA
      AND tr.id_proveedor = P_ID_PROVEEDOR;

    IF V_ID_REGLA IS NULL THEN
        RAISE EXCEPTION 'La regla de tarifa % no existe o no pertenece al proveedor %',
            P_ID_REGLA,
            P_ID_PROVEEDOR;
    END IF;

    -- verificar contrato activo
    SELECT cet.id_contrato
    INTO V_ID_CONTRATO_ACTIVO
    FROM contrato_empresa_tarifas cet
    WHERE cet.id_empresa = P_ID_EMPRESA
      AND cet.id_proveedor = P_ID_PROVEEDOR
      AND cet.activo = TRUE
      AND (
        cet.vigente_hasta IS NULL
            OR cet.vigente_hasta >= CURRENT_TIMESTAMP
        )
    LIMIT 1;

    IF V_ID_CONTRATO_ACTIVO IS NOT NULL THEN
        RAISE EXCEPTION 'Ya existe un contrato activo para la empresa % con el proveedor %. Contrato activo: %',
            P_ID_EMPRESA,
            P_ID_PROVEEDOR,
            V_ID_CONTRATO_ACTIVO;
    END IF;

    -- validar fechas
    IF P_VIGENTE_HASTA IS NOT NULL
        AND P_VIGENTE_HASTA <= P_VIGENTE_DESDE THEN
        RAISE EXCEPTION 'La fecha vigente_hasta debe ser mayor que vigente_desde';
    END IF;

    -- validar detalles
    IF P_DETALLES IS NULL OR jsonb_array_length(P_DETALLES) = 0 THEN
        RAISE EXCEPTION 'Debe enviar al menos un detalle para el contrato';
    END IF;

    -- validar que ningún descuento sea negativo
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_DETALLES) AS detalle
        WHERE (detalle->>'porcentaje_descuento')::DECIMAL(14,2) < 0
        OR (detalle->>'porcentaje_descuento')::DECIMAL(14,2) > 100
    ) THEN
        RAISE EXCEPTION 'El porcentaje de descuento no puede ser negativo o mayor a 100';
    END IF;

    -- validar que ningún SKU sea NULL o vacío
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_DETALLES) AS detalle
        WHERE detalle->>'sku' IS NULL
           OR detalle->>'sku' = ''
    ) THEN
        RAISE EXCEPTION 'El SKU no puede ser NULL ni vacío';
    END IF;

    -- validar que todos los SKU existan en producto
    IF EXISTS (
        SELECT 1
        FROM jsonb_array_elements(P_DETALLES) AS detalle
                 LEFT JOIN producto p
                           ON p.sku = detalle->>'sku'
        WHERE p.sku IS NULL
    ) THEN
        RAISE EXCEPTION 'Uno o más productos del detalle no existen';
    END IF;

    -- crear contrato
    INSERT INTO contrato_empresa_tarifas (
        id_empresa,
        id_proveedor,
        id_regla,
        vigente_desde,
        vigente_hasta,
        activo
    )
    VALUES (
               P_ID_EMPRESA,
               P_ID_PROVEEDOR,
               P_ID_REGLA,
               P_VIGENTE_DESDE,
               P_VIGENTE_HASTA,
               TRUE
           )
    RETURNING id_contrato INTO V_ID_CONTRATO_NUEVO;

    -- insertar detalles
    INSERT INTO contrato_empresa_detalle (
        porcentaje_descuento,
        sku,
        id_contrato
    )
    SELECT
        (detalle->>'porcentaje_descuento')::DECIMAL(14,2),
        detalle->>'sku',
        V_ID_CONTRATO_NUEVO
    FROM jsonb_array_elements(P_DETALLES) AS detalle;

    RAISE INFO 'Contrato creado correctamente. ID contrato: %', V_ID_CONTRATO_NUEVO;
END;
$$  LANGUAGE plpgsql;

---------------------------------
-- AGREGAR PRODUCTO 
------------
CREATE OR REPLACE PROCEDURE SP_AGREGAR_PRODUCTOS (
    P_NOMBRE VARCHAR,
    P_DESCRIPCION TEXT,
    P_UNIDAD_MEDIDA VARCHAR,
    P_ID_CATEGORIA UUID,
    P_SKU VARCHAR
)
AS $$
    DECLARE
        V_ID_CATEGORIA UUID;


    BEGIN

        SELECT id_categoria
        INTO V_ID_CATEGORIA
        FROM categoria
        WHERE id_categoria = P_ID_CATEGORIA;


        IF EXISTS (
            SELECT 1
            FROM producto
            WHERE sku = P_SKU
        ) THEN
            RAISE EXCEPTION 'Ya existe un producto con el SKU %', P_SKU;

        END IF;


        IF NOT EXISTS (
            SELECT 1
            FROM CATEGORIA
            WHERE id_categoria = V_ID_CATEGORIA
        ) THEN
            RAISE EXCEPTION 'LA ID DE CATEGORIA %, NO EXISTE EN LA DB',
                V_ID_CATEGORIA;

        end if;

        INSERT INTO PRODUCTO (SKU, NOMBRE, DESCRIPCION, UNIDAD_MEDIDA, ID_CATEGORIA)
        VALUES (P_SKU, P_NOMBRE, P_DESCRIPCION,P_UNIDAD_MEDIDA, P_ID_CATEGORIA);

end;
    $$ LANGUAGE  plpgsql;


----------------------
-- AGREGAR PRECIO BASE
--------------------------
CREATE OR REPLACE PROCEDURE SP_AGREGAR_PRECIO_BASE (
    P_SKU VARCHAR,
    P_ID_PROVEEDOR UUID,
    P_PRECIO_BASE DECIMAL(14,2),
    P_VIGENTE_DESDE TIMESTAMP,
    P_VIGENTE_HASTA TIMESTAMP
)
AS $$
DECLARE
    V_SKU VARCHAR;
    V_ID_PROVEEDOR UUID;
    V_ID_PRECIO_ACTIVO UUID;
BEGIN
    -- validar que el producto exista
    SELECT sku
    INTO V_SKU
    FROM producto
    WHERE sku = P_SKU;

    IF V_SKU IS NULL THEN
        RAISE EXCEPTION 'El producto con SKU % no existe', P_SKU;
    END IF;

    -- validar que el proveedor exista
    SELECT id_proveedor
    INTO V_ID_PROVEEDOR
    FROM proveedor
    WHERE id_proveedor = P_ID_PROVEEDOR;

    IF V_ID_PROVEEDOR IS NULL THEN
        RAISE EXCEPTION 'El proveedor con ID % no existe', P_ID_PROVEEDOR;
    END IF;

    -- validar que el precio sea positivo
    IF P_PRECIO_BASE <= 0 THEN
        RAISE EXCEPTION 'El precio base debe ser mayor a 0';
    END IF;

    -- validar fechas
    IF P_VIGENTE_HASTA IS NOT NULL
        AND P_VIGENTE_HASTA <= P_VIGENTE_DESDE THEN
        RAISE EXCEPTION 'La fecha vigente_hasta debe ser mayor que vigente_desde';
    END IF;

    --   validar que no exista un precio base activo para ese producto y proveedor
    SELECT id_precio
    INTO V_ID_PRECIO_ACTIVO
    FROM precio_base
    WHERE sku = P_SKU
      AND id_proveedor = P_ID_PROVEEDOR
      AND (
        vigente_hasta IS NULL
            OR vigente_hasta >= CURRENT_TIMESTAMP
        )
    LIMIT 1;

    IF V_ID_PRECIO_ACTIVO IS NOT NULL THEN
        RAISE EXCEPTION 'Ya existe un precio base activo para el producto % con el proveedor %',
            P_SKU,
            P_ID_PROVEEDOR;
    END IF;

    -- insertar precio base
    INSERT INTO precio_base (
        precio_base,
        vigente_desde,
        vigente_hasta,
        id_proveedor,
        sku
    )
    VALUES (P_PRECIO_BASE,P_VIGENTE_DESDE,P_VIGENTE_HASTA,P_ID_PROVEEDOR,P_SKU);

    RAISE INFO 'Precio base agregado correctamente. Producto: %, Proveedor: %, Precio: %',
        P_SKU,
        P_ID_PROVEEDOR,
        P_PRECIO_BASE;
END;
$$ LANGUAGE plpgsql;

