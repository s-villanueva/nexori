DROP VIEW IF EXISTS v_tarifas_publicas_producto;

CREATE VIEW v_tarifas_publicas_producto AS
SELECT
    p.sku,
    p.nombre AS producto,
    p.descripcion,
    p.unidad_medida,

    e.nombre AS proveedor,
    a.nombre AS almacen,
    pa.stock,

    pb.precio_base,
    pb.vigente_desde,
    pb.vigente_hasta
FROM producto p
JOIN producto_almacen pa
    ON pa.sku = p.sku
JOIN almacen a
    ON a.id_almacen = pa.id_almacen
JOIN proveedor pr
    ON pr.id_proveedor = a.id_proveedor
JOIN empresa e
    ON e.id_empresa = pr.id_empresa
JOIN precio_base pb
    ON pb.sku = p.sku
   AND pb.id_proveedor = pr.id_proveedor
WHERE p.activo = TRUE
  AND pa.activo = TRUE
  AND a.activo = TRUE
  AND pr.activo = TRUE
  AND e.activo = TRUE
  AND pa.stock > 0
  AND pb.vigente_desde <= CURRENT_TIMESTAMP
  AND (
        pb.vigente_hasta IS NULL
        OR pb.vigente_hasta >= CURRENT_TIMESTAMP
  );
